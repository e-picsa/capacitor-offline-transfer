{
  "name": "@picsa/capacitor-offline-transfer",
  "version": "8.1.5",
  "workspaces": [
    "example"
  ],
  "description": "Capacitor plugin for offline, large file transfer (Android Nearby & iOS Multipeer)",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "PicsaCapacitorOfflineTransfer.podspec"
  ],
  "author": "E-Picsa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e-picsa/capacitor-offline-transfer.git"
  },
  "bugs": {
    "url": "https://github.com/e-picsa/capacitor-offline-transfer/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "offline-transfer",
    "multipeer",
    "nearby"
  ],
  "scripts": {
    "start": "bun run scripts/dev.ts",
    "verify": "bun run verify:ios && bun run verify:android && bun run verify:web",
    "verify:ios": "xcodebuild -scheme PicsaCapacitorOfflineTransfer -destination 'platform=iOS Simulator,name=iPhone 15' test",
    "verify:android": "cd android && ./gradlew clean build testDebugUnitTest && cd ..",
    "verify:web": "bun run build",
    "example:build": "cd example && bun run build && cd ..",
    "example:android": "bun run example:build && bunx cap run android && cd ..",
    "example:ios": "bun run example:build && bunx cap run ios && cd ..",
    "lint": "bun run eslint && bun run prettier -- --check && bun run swiftlint -- lint",
    "fmt": "bun run eslint -- --fix && bun run prettier -- --write && bun run swiftlint -- --fix --format",
    "eslint": "eslint .",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api OfflineTransferPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "bun run clean && bun run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "bun run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/docgen": "^0.3.1",
    "@capacitor/ios": "^8.0.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@types/bun": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "8",
    "@typescript-eslint/parser": "8",
    "eslint": "9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-java": "^2.7.7",
    "rimraf": "^6.1.0",
    "rollup": "^4.59.0",
    "swiftlint": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.java": [
      "prettier --write"
    ],
    "*.swift": [
      "swiftlint --fix --format"
    ]
  },
  "swiftlint": "@ionic/swiftlint-config",
  "publishConfig": {
    "access": "public"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
